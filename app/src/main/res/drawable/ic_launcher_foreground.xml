<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="12dp"
        android:gravity="left|center_vertical">
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:startColor="#EF1970"
                android:centerColor="#F77D35"
                android:endColor="#FFD600" />
            <size
                android:width="26dp"
                android:height="26dp" />
        </shape>
    </item>

    <item
        android:left="16dp"
        android:gravity="left|center_vertical"
        android:width="18dp"
        android:height="18dp"
        android:drawable="@drawable/launch_logo_symbol" />

    <item
        android:left="44dp"
        android:gravity="left|center_vertical"
        android:width="50dp"
        android:height="21dp"
        android:drawable="@drawable/odysee_wordmark_text" />
</layer-list>
